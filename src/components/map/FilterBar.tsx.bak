      description: "Lugares turísticos y actividades",
    },
    {
      id: "animals",
      name: "Fauna",
      category: "animals",
      icon: "🐋",
      description: "Animales y vida silvestre",
    },
    {
      id: "festivals",
      name: "Festivales",
      category: "festivals",
      icon: "🎭",
      description: "Festivales y eventos culturales",
    },
  ];

  return (
    <div className="space-y-4">
      {/* Barra de búsqueda */}
      <div className="relative">
        <input
