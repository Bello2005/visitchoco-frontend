import React from "react";
import type { Municipality } from "../../services/municipality.service";
import type { FilterType, IndigenousReserve, TouristSpot } from "../../types/filters";

interface InfoPanelProps {
  selectedMunicipality: Municipality;
  activeFilter?: FilterType;
  selectedReserves?: IndigenousReserve[];
  selectedSpots?: TouristSpot[];
}

const InfoPanel: React.FC<InfoPanelProps> = ({
  selectedMunicipality,
  activeFilter = "general",
  selectedReserves = [],
  selectedSpots = []
}) => {
  return (
    <div className="space-y-4">
      {activeFilter === "general" && (
        <div className="space-y-4">
          {selectedMunicipality.main_activity && (
            <div className="bg-white/80 backdrop-blur-sm rounded-2xl p-4 shadow-sm border border-gray-100/60">
              <h3 className="text-sm text-gray-500 mb-1">Actividad Principal</h3>
              <p className="text-gray-800">{selectedMunicipality.main_activity}</p>
            </div>
          )}
          
          {selectedMunicipality.description && (
            <div className="prose prose-sm max-w-none">
              <p className="text-gray-600">{selectedMunicipality.description}</p>
            </div>
          )}
        </div>
      )}
    </div>
  );
};

export default InfoPanel;
